---
import MarkdownLayout from '../../layouts/MarkdownLayout.astro';

export async function getStaticPaths() {
  const files = import.meta.glob('../../content-md/*.md', { eager: true });
  return Object.entries(files).map(([path, mod]) => {
    const slug = path.split('/').pop().replace('.md', '');
    return {
      params: { slug },
      props: { mod }
    };
  });
}

const { mod } = Astro.props;
const { Content, frontmatter } = mod;
---

<MarkdownLayout
  title={frontmatter.title}
  sourceFile={frontmatter.sourceFile}
  slug={frontmatter.slug}
  readingMinutes={frontmatter.readingMinutes}
  density={frontmatter.density}
>
  <Content />
</MarkdownLayout>
