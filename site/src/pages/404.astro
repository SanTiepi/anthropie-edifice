---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<html lang="fr">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="robots" content="noindex" />
		<title>404 — L'Anthropie</title>
		<style>
			body {
				font-family: 'Iowan Old Style', 'Palatino Linotype', Palatino, 'Hoefler Text', Georgia, serif;
				color: #1a1a1a;
				background: #fdfdfb;
				margin: 0;
				min-height: 100vh;
				display: flex;
				flex-direction: column;
				align-items: center;
				justify-content: center;
				text-align: center;
				padding: 2rem;
			}
			.code {
				font-family: 'SF Mono', Menlo, Consolas, monospace;
				font-size: 5rem;
				color: #4a6741;
				margin: 0;
				letter-spacing: 0.02em;
			}
			h1 {
				font-size: 1.6rem;
				font-weight: 400;
				margin: 0.5rem 0 1.5rem;
			}
			p {
				color: #5a5a5a;
				max-width: 460px;
				font-style: italic;
				line-height: 1.6;
			}
			a {
				display: inline-block;
				margin-top: 1.5rem;
				padding: 0.55rem 1rem;
				border: 1px solid #4a6741;
				color: #4a6741;
				text-decoration: none;
				font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
				font-size: 0.9rem;
			}
			a:hover {
				background: #4a6741;
				color: #fdfdfb;
			}
		</style>
	</head>
	<body>
		<p class="code">404</p>
		<h1>Cette page ne se trouve pas dans l'édifice.</h1>
		<p>« Le porteur vient après. »<br />Peut-être cette page n'existe pas encore — ou n'existera jamais.</p>
		<a href={`${base}/`}>Retour à l'accueil</a>
	</body>
</html>
