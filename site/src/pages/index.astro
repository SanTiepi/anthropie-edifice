---
import { couches, articles, githubBase } from "../data/couches";
import CouchesSchema from "../components/CouchesSchema.astro";
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<html lang="fr">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content="L'Anthropie — édifice civilisationnel d'apprentissage humain à 12 couches, 0 à infini. CC0 1.0 Universal. Sans signature personnelle. Cherche porteurs." />
		<meta property="og:title" content="L'Anthropie — édifice civilisationnel CC0" />
		<meta property="og:description" content="12 couches d'apprentissage humain, 0 à infini. 11 articles juridiques 31bis-duodecies. Domaine public." />
		<meta property="og:type" content="website" />
		<meta property="og:url" content="https://anthropie.org/" />
		<meta property="og:image" content="https://anthropie.org/og-image.svg" />
		<meta property="og:locale" content="fr_FR" />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:image" content="https://anthropie.org/og-image.svg" />
		<link rel="canonical" href="https://anthropie.org/" />
		<meta name="theme-color" content="#4a6741" />
		<meta name="author" content="Anthropie Network" />
		<meta name="dcterms.rights" content="CC0 1.0 Universal — Public Domain Dedication" />
		<title>L'Anthropie — édifice civilisationnel CC0</title>
		<script type="application/ld+json" set:html={JSON.stringify({
			"@context": "https://schema.org",
			"@type": "CreativeWork",
			"name": "L'Anthropie — édifice civilisationnel d'apprentissage humain",
			"alternateName": "L'Anthropie",
			"description": "Édifice civilisationnel d'apprentissage humain à 12 couches (0 à infini). Onze articles juridiques 31bis-duodecies. Domaine public.",
			"url": "https://anthropie.org/",
			"inLanguage": "fr",
			"license": "https://creativecommons.org/publicdomain/zero/1.0/",
			"creator": { "@type": "Organization", "name": "Anthropie Network" },
			"copyrightNotice": "CC0 1.0 Universal — Public Domain Dedication. No rights reserved.",
			"keywords": ["éducation", "apprentissage", "droits de l'enfant", "Convention CRC", "31bis", "civilisation", "anthropologie", "12 couches", "Anthropie"],
			"genre": "civic infrastructure proposal",
			"isAccessibleForFree": true,
			"hasPart": [
				{ "@type": "CreativeWork", "name": "Couche 1 — La Matrice (0-3)", "url": "https://github.com/SanTiepi/anthropie-edifice/blob/master/anthropie_couche_01_matrice.md" },
				{ "@type": "CreativeWork", "name": "Couche 2 — Le Sanctuaire (3-7)", "url": "https://github.com/SanTiepi/anthropie-edifice/blob/master/anthropie_couche_02_sanctuaire.md" },
				{ "@type": "CreativeWork", "name": "Couche 3 — L'Atelier (5-12)", "url": "https://github.com/SanTiepi/anthropie-edifice/blob/master/anthropie_couche_03_atelier.md" },
				{ "@type": "CreativeWork", "name": "Couche 4 — La Parole (7-15)", "url": "https://github.com/SanTiepi/anthropie-edifice/blob/master/anthropie_couche_04_parole.md" },
				{ "@type": "CreativeWork", "name": "Couche 5 — La Ville (10-18)", "url": "https://github.com/SanTiepi/anthropie-edifice/blob/master/anthropie_couche_05_ville.md" },
				{ "@type": "CreativeWork", "name": "Couche 6 — Le Regard (10-18)", "url": "https://github.com/SanTiepi/anthropie-edifice/blob/master/anthropie_couche_06_regard.md" },
				{ "@type": "CreativeWork", "name": "Couche 7 — Les Seuils (12-22)", "url": "https://github.com/SanTiepi/anthropie-edifice/blob/master/anthropie_couche_07_seuils.md" },
				{ "@type": "CreativeWork", "name": "Couche 8 — La Mycologie (15-25)", "url": "https://github.com/SanTiepi/anthropie-edifice/blob/master/anthropie_couche_08_mycologie.md" },
				{ "@type": "CreativeWork", "name": "Couche 9 — L'Archive vivante (0-∞)", "url": "https://github.com/SanTiepi/anthropie-edifice/blob/master/anthropie_couche_09_archive.md" },
				{ "@type": "CreativeWork", "name": "Couche 10 — Le Conseil des morts (4-∞)", "url": "https://github.com/SanTiepi/anthropie-edifice/blob/master/anthropie_couche_10_morts.md" },
				{ "@type": "CreativeWork", "name": "Couche 11 — La Parenté élargie (3-25)", "url": "https://github.com/SanTiepi/anthropie-edifice/blob/master/anthropie_couche_11_parente.md" },
				{ "@type": "CreativeWork", "name": "Couche 12 — Le Seuil de la brisure (9-∞)", "url": "https://github.com/SanTiepi/anthropie-edifice/blob/master/anthropie_couche_12_brisure.md" }
			]
		})} />

		<style>
			:root {
				--text: #1a1a1a;
				--muted: #5a5a5a;
				--bg: #fdfdfb;
				--bg-alt: #f4f2ec;
				--accent: #4a6741;
				--accent-dark: #3a5631;
				--border: #e2dfd6;
				--max: 760px;
			}
			* { box-sizing: border-box; }
			html { scroll-behavior: smooth; }
			body {
				font-family: 'Iowan Old Style', 'Palatino Linotype', Palatino, 'Hoefler Text', Georgia, serif;
				font-size: 17px;
				line-height: 1.65;
				color: var(--text);
				background-color: var(--bg);
				margin: 0;
				padding: 0;
			}
			header {
				border-bottom: 1px solid var(--border);
				padding: 4rem 1.5rem 3rem;
				text-align: center;
			}
			header h1 {
				font-size: 3rem;
				font-weight: 400;
				letter-spacing: 0.02em;
				margin: 0 0 0.5rem;
			}
			header .sub {
				font-style: italic;
				color: var(--muted);
				margin: 0 auto;
				max-width: 560px;
				font-size: 1.05rem;
			}
			main {
				max-width: var(--max);
				margin: 0 auto;
				padding: 2.5rem 1.5rem 4rem;
			}
			section { margin: 3rem 0; }
			section:first-of-type { margin-top: 1rem; }
			h2 {
				font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
				font-size: 0.85rem;
				font-weight: 600;
				text-transform: uppercase;
				letter-spacing: 0.18em;
				color: var(--accent);
				margin: 0 0 1.2rem;
				padding-bottom: 0.4rem;
				border-bottom: 1px solid var(--border);
			}
			h3 {
				font-size: 1.25rem;
				font-weight: 400;
				margin: 1.6rem 0 0.6rem;
			}
			p { margin: 0.8em 0; }
			a {
				color: var(--accent);
				text-decoration: none;
				border-bottom: 1px solid rgba(74, 103, 65, 0.3);
				transition: border-color 0.15s;
			}
			a:hover { border-bottom-color: var(--accent); }
			strong { font-weight: 600; }
			em { color: var(--muted); }
			ul, ol { padding-left: 1.4rem; }
			li { margin: 0.3rem 0; }
			.quote {
				border-left: 3px solid var(--accent);
				padding: 0.2rem 0 0.2rem 1.2rem;
				margin: 1.5rem 0;
				color: var(--muted);
				font-style: italic;
			}
			table {
				width: 100%;
				border-collapse: collapse;
				margin: 1rem 0;
				font-size: 0.95rem;
			}
			th, td {
				border-bottom: 1px solid var(--border);
				padding: 0.6rem 0.5rem;
				text-align: left;
				vertical-align: top;
			}
			th {
				font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
				font-size: 0.78rem;
				font-weight: 600;
				text-transform: uppercase;
				letter-spacing: 0.1em;
				color: var(--muted);
				background: transparent;
			}
			td.num { color: var(--muted); width: 2.2rem; }
			td.age { color: var(--muted); width: 4rem; white-space: nowrap; }
			td.couche { font-weight: 500; min-width: 9rem; }
			.articles-list {
				list-style: none;
				padding: 0;
				margin: 1rem 0;
			}
			.articles-list li {
				border-bottom: 1px dotted var(--border);
				padding: 0.55rem 0;
			}
			.articles-list .code {
				display: inline-block;
				font-family: 'SF Mono', Menlo, Consolas, monospace;
				font-size: 0.85rem;
				color: var(--accent);
				min-width: 6.5rem;
				font-weight: 500;
			}
			.articles-list a.article-link {
				color: var(--text);
				text-decoration: none;
				border-bottom: none;
			}
			.articles-list a.article-link:hover {
				color: var(--accent);
			}
			.articles-list a.article-link:hover .code {
				text-decoration: underline;
			}
			.articles-list .article-couche-ref {
				color: var(--muted);
				font-style: italic;
				font-size: 0.85rem;
				margin-left: 0.4rem;
			}
			.tldr {
				background: var(--bg-alt);
				border-left: 3px solid var(--accent);
				padding: 1rem 1.2rem;
				margin: 1.5rem 0;
				font-size: 0.95rem;
			}
			.tldr ul { margin: 0.4rem 0; padding-left: 1.2rem; }
			ul.principes {
				list-style: none;
				padding: 0;
				margin: 1.2rem 0;
				font-size: 0.95rem;
				border-top: 1px solid var(--border);
				border-bottom: 1px solid var(--border);
			}
			ul.principes li {
				padding: 0.55rem 0;
				border-bottom: 1px dotted var(--border);
			}
			ul.principes li:last-child { border-bottom: none; }
			ul.principes strong {
				font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
				font-size: 0.78rem;
				font-weight: 600;
				text-transform: uppercase;
				letter-spacing: 0.12em;
				color: var(--accent);
				display: inline-block;
				min-width: 9rem;
			}
			ol.quatre-portes {
				list-style: none;
				padding: 0;
				margin: 1.4rem 0;
				counter-reset: porte;
			}
			ol.quatre-portes > li {
				padding: 1rem 0;
				border-top: 1px solid var(--border);
				margin: 0;
				font-size: 0.95rem;
			}
			ol.quatre-portes > li:last-child { border-bottom: 1px solid var(--border); }
			ol.quatre-portes > li > strong {
				font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
				font-size: 0.85rem;
				font-weight: 600;
				text-transform: uppercase;
				letter-spacing: 0.14em;
				color: var(--accent);
			}
			ol.quatre-portes .porte-desc {
				color: var(--muted);
				font-style: italic;
				font-size: 0.92rem;
			}
			p.biblio-intro {
				font-size: 0.88rem;
				color: var(--muted);
				font-style: italic;
				margin-top: 1.5rem;
			}
			details.biblio-complete {
				margin: 0.8rem 0 1rem;
				font-size: 0.92rem;
			}
			details.biblio-complete > summary {
				cursor: pointer;
				padding: 0.6rem 0;
				font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
				font-size: 0.78rem;
				text-transform: uppercase;
				letter-spacing: 0.12em;
				color: var(--accent);
				border-bottom: 1px solid var(--border);
			}
			details.biblio-complete > summary:hover { color: var(--accent-dark); }
			details.biblio-complete[open] > summary { margin-bottom: 0.6rem; }
			details.biblio-complete ul {
				margin-top: 0.8rem;
				padding-left: 1.2rem;
			}
			details.biblio-complete li {
				padding: 0.35rem 0;
				border-bottom: 1px dotted var(--border);
				font-size: 0.92rem;
			}
			details.biblio-complete li:last-child { border-bottom: none; }
			.skip-link {
				position: absolute;
				left: -9999px;
				top: 0;
				background: var(--accent);
				color: var(--bg);
				padding: 0.5rem 1rem;
				z-index: 100;
				font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
				font-size: 0.85rem;
				border-bottom: none;
			}
			.skip-link:focus {
				left: 0.5rem;
				top: 0.5rem;
				outline: 2px solid var(--accent-dark);
				outline-offset: 2px;
			}
			:focus-visible {
				outline: 2px solid var(--accent);
				outline-offset: 2px;
			}
			td.maturite {
				white-space: nowrap;
				font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
				font-size: 0.78rem;
				color: var(--muted);
			}
			td.maturite-robuste span[aria-hidden="true"] { color: #4a6741; }
			td.maturite-sensible span[aria-hidden="true"] { color: #b8860b; }
			.maturite-label { display: inline-block; }
			strong.maturite-robuste-label { color: #4a6741; }
			strong.maturite-sensible-label { color: #b8860b; }
			@media (max-width: 600px) {
				td.maturite { font-size: 0.7rem; }
				.maturite-label { display: none; }
			}
			@media print {
				header, footer { border: none; padding: 1rem 0; }
				header h1 { font-size: 2rem; }
				main { padding: 0; max-width: none; }
				.cta-row, .cta { display: none; }
				a { color: var(--text); border-bottom: none; }
				body { font-size: 12pt; line-height: 1.5; }
			}
			.cta-row {
				display: flex;
				flex-wrap: wrap;
				gap: 0.6rem;
				margin: 1.5rem 0;
			}
			.cta {
				display: inline-block;
				padding: 0.55rem 1rem;
				border: 1px solid var(--accent);
				color: var(--accent);
				font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
				font-size: 0.9rem;
				border-bottom: 1px solid var(--accent);
			}
			.cta:hover {
				background: var(--accent);
				color: var(--bg);
				border-bottom-color: var(--accent);
			}
			footer {
				border-top: 1px solid var(--border);
				padding: 2.5rem 1.5rem;
				text-align: center;
				color: var(--muted);
				font-size: 0.9rem;
			}
			footer p { margin: 0.4em 0; }
			@media (max-width: 600px) {
				header { padding: 2.5rem 1rem 2rem; }
				header h1 { font-size: 2.2rem; }
				main { padding: 1.5rem 1rem 3rem; }
				body { font-size: 16px; }
				th, td { padding: 0.5rem 0.3rem; font-size: 0.9rem; }
			}
		</style>
	</head>
	<body>
		<a class="skip-link" href="#main">Aller au contenu</a>
		<header>
			<h1>L'Anthropie</h1>
			<p class="sub">Édifice civilisationnel d'apprentissage humain à 12 couches — de 0 à l'infini. Domaine public.</p>
		</header>

		<main id="main">

			<section>
				<p>L'Anthropie est un édifice civilisationnel construit sous licence <a href={`${githubBase}/LICENSE.md`}>CC0 1.0 Universal</a>. Personne ne le possède. Toute personne ou collectif peut l'utiliser, le modifier, le traduire, l'incarner, le contester, l'augmenter — sans demander permission, sans rétribution, sans attribution exigée.</p>
				<p class="quote">L'édifice cherche ses porteurs. Vous êtes peut-être l'un d'eux.</p>
				<ul class="principes" aria-label="Trois principes non négociables">
					<li><strong>Anonymat strict</strong> — l'édifice n'a pas d'auteur. Footer : <em>Anthropie Network</em>.</li>
					<li><strong>CC0 1.0 intégral</strong> — domaine public, aucun droit revendiqué, aucune attribution exigée.</li>
					<li><strong>Anti-marketing</strong> — pas de tracking, pas de framework JS lourd, pas de funnel de conversion.</li>
				</ul>
				<p style="font-size: 0.88rem; color: var(--muted); margin-top: 0.6rem;"><strong>L'Anthropie n'est pas Anthropic, n'est pas un laboratoire d'IA, n'est pas un produit.</strong> Voir <a href={`${base}/lire/pas-un-labo-ia/`}>la clarification anti-confusion</a> si vous arrivez par homonymie.</p>
				<div class="cta-row">
					<a class="cta" href={`${base}/lire/brief/`}>Brief 3 min</a>
					<a class="cta" href={`${base}/lire/noyau/`}>Noyau 10 min</a>
					<a class="cta" href={`${base}/lire/garde-fous/`}>Garde-fous</a>
					<a class="cta" href={`${base}/lire/adequation/`}>Test d'adéquation 90 s</a>
					<a class="cta" href="https://github.com/SanTiepi/anthropie-edifice">Repository</a>
				</div>
			</section>

			<section aria-labelledby="parcours">
				<h2 id="parcours">Parcours de lecture</h2>
				<div class="tldr">
					<ul>
						<li><strong>90 secondes</strong> — <a href={`${base}/lire/adequation/`}>test d'adéquation</a> (sept questions oui/non pour s'auto-exclure rapidement si la doctrine ne convient pas)</li>
						<li><strong>3 minutes</strong> — <a href={`${base}/lire/brief/`}>le brief</a> (présentation compacte)</li>
						<li><strong>10 minutes</strong> — <a href={`${base}/lire/noyau/`}>le noyau</a> : distillation pour décider en lecture courte</li>
						<li><strong>15 minutes</strong> — <a href={`${base}/lire/apercu-12-couches/`}>aperçu des 12 couches</a> : ~150 mots par couche, palier intermédiaire avant les fichiers complets</li>
						<li><strong>30 minutes</strong> — une couche complète, idéalement <a href={`${base}/lire/couche-04-parole/`}>Couche 4 LA PAROLE</a> (Discipline de Prédiction-Avant-Vocal anti-LLM-flattening) ou <a href={`${base}/lire/couche-12-brisure/`}>Couche 12 LE SEUIL DE LA BRISURE</a> (Hospices + Kintsugi)</li>
						<li><strong>Une journée</strong> — lecture intégrale des douze fichiers de couche</li>
					</ul>
					<p style="margin-top: 0.8rem; font-size: 0.9rem;"><strong>Avant tout prototype ou contact terrain</strong> — lire <a href={`${base}/lire/garde-fous/`}>SAFETY</a> (protection mineurs, non-thérapie, anti-secte, co-design souverain, AI-non-substitution) et <a href={`${base}/lire/prototyper/`}>PROTOTYPES</a> (formats 2h/1mois/12mois + critères d'arrêt).</p>
				</div>
			</section>

			<section>
				<h2>Le diagnostic</h2>
				<p><strong>Premier constat — la fenêtre de bascule est étroite.</strong> AGI déployée à grande échelle dans 5-10 ans, cascades climatiques 2030-2050, instabilités géopolitiques cumulatives. Les modèles classiques de transformation éducative (Reggio 60 ans, Sudbury 50 ans, AA 90 ans) sont trop lents. Les enfants qui ont 5 ans en 2026 traverseront leur adolescence dans la bascule, leur âge adulte dans le post-bascule. Ils ne sont pas préparés.</p>
				<p><strong>Deuxième constat — la crise mentale jeunesse documentée 2014-2024.</strong> Suicide 10-24 ans +56&nbsp;% en 10 ans (USA, <em>Frontiers Psychiatry</em> 2024), Black youth +78&nbsp;%. Eco-anxiety Gen Z ~50&nbsp;% niveau élevé. UNICEF&nbsp;: 1 enfant sur 3 victime mensuelle de bullying. UNESCO&nbsp;: <em>«&nbsp;crisis of knowing&nbsp;»</em> face aux deepfakes. La génération qui doit porter l'avenir est en effondrement structurel.</p>
				<p><strong>Troisième constat — les frameworks existants sont fragmentés.</strong> Reggio Emilia couvre 0-6 ans magnifiquement. Big Picture Learning 14-18 superbement. Bildung Nordique jusqu'à l'âge adulte. Te Whāriki biculturel. Día de los Muertos pour les morts. Whanganui Te Awa Tupua pour les non-humains. AA pour les brisures. <strong>Mais aucun édifice ne les articule en un protocole civilisationnel cohérent 0-∞ avec charpente juridique.</strong></p>
			</section>

			<section>
				<h2>Les 12 couches</h2>
				<table>
					<thead>
						<tr><th>#</th><th>Couche</th><th>Âge</th><th>Cœur</th><th title="Maturité épistémique : robuste = convergence empirique ou précédent juridique fort ; sensible = arbitrages culturels, juridiques ou opérationnels en cours" aria-label="Maturité épistémique">État</th></tr>
					</thead>
					<tbody>
						{couches.map(c => (
							<tr>
								<td class="num">{c.n}</td>
								<td class="couche">
									{c.hasFile ? <a href={`${base}/lire/${c.slug}/`}>{c.nom}</a> : c.nom}
								</td>
								<td class="age">{c.age}</td>
								<td>{c.coeur}</td>
								<td class={`maturite maturite-${c.maturite}`}><span aria-hidden="true">●</span> <span class="maturite-label">{c.maturite}</span></td>
							</tr>
						))}
					</tbody>
				</table>
				<p>Chaque couche a sept strates, des droits fondamentaux, un audit matriciel à 70 cellules, un déploiement fractal du camp de réfugié à la métropole mature, des articulations explicites avec les autres couches, et des angles morts assumés honnêtement. <em>État</em> = maturité épistémique de la couche : <strong class="maturite-robuste-label">robuste</strong> (convergence empirique ou précédent juridique fort) ou <strong class="maturite-sensible-label">sensible</strong> (arbitrages culturels, juridiques ou opérationnels en cours).</p>
				<CouchesSchema />
			</section>

			<section>
				<h2>Charpente juridique — Protocole optionnel CRC</h2>
				<p>Onze articles d'extension du protocole optionnel à la <em>Convention relative aux droits de l'enfant</em> :</p>
				<ul class="articles-list">
					{articles.map(a => {
						const coucheSrc = couches.find(c => c.n === a.coucheSource);
						return (
							<li>
								<a href={`${base}/lire/${coucheSrc?.slug}/`} class="article-link">
									<span class="code">Art. {a.code}</span>{a.titre}
								</a>
								{coucheSrc && (
									<span class="article-couche-ref"> — Couche {a.coucheSource} {coucheSrc.nom}</span>
								)}
							</li>
						);
					})}
				</ul>
				<p>Cinq États-pilotes identifiés : Norvège, Costa Rica, Nouvelle-Zélande, Bhoutan, Québec. Effet domino visé&nbsp;: 30+ ratifications d'ici 2045.</p>
			</section>

			<section>
				<h2>Pour contribuer</h2>
				<p>Voir <a href={`${base}/lire/contribuer/`}>CONTRIBUTING</a>. Six modes&nbsp;:</p>
				<ol>
					<li><strong>Lire et signaler</strong> ce qui résonne, dérange, manque (<a href="https://github.com/SanTiepi/anthropie-edifice/issues">Issues GitHub</a>)</li>
					<li><strong>Co-designer</strong> une couche qui aligne avec votre travail (Pull Request)</li>
					<li><strong>Prototyper</strong> localement (cf. <a href={`${base}/lire/prototyper/`}>PROTOTYPES</a> pour formats 2h / 1 mois / 12 mois)</li>
					<li><strong>Plaidoyer</strong> institutionnel (universitaire, philanthropique, gouvernemental)</li>
					<li><strong>Traduire</strong> dans une langue (priorité&nbsp;: EN, ES, AR, ZH, HI, SW, PT)</li>
					<li><strong>Critique radicale</strong> publique des pièces qui ne tiennent pas (cf. <a href={`${base}/lire/refutation/`}>critères de réfutation</a>)</li>
				</ol>
			</section>

			<section>
				<h2>Pour les communautés autochtones</h2>
				<p>L'édifice mobilise des références aux traditions vivantes (Maori <em>Te Whāriki</em> et <em>Te Awa Tupua</em>, Anishinaabe pédagogie de la terre, Aboriginal <em>8 Ways</em>, Saami land-based, Yoruba Egúngún, Lakota Conseil, Día de los Muertos). Toute adaptation/co-design d'une couche pour une tradition spécifique respecte la <strong>charte anti-appropriation</strong> (Couche 7 Strate 5)&nbsp;:</p>
				<ol>
					<li>L'initiative vient de la communauté, pas de l'édifice</li>
					<li>Co-designers rémunérés au tarif Compagnon-Maître senior</li>
					<li>Souveraineté communautaire absolue, retrait possible à tout moment (90 jours)</li>
					<li>Pas de transposition extra-communautaire sans nouveau co-design</li>
				</ol>
				<p>Si une partie de l'édifice cite incorrectement votre tradition, ouvrez une <a href="https://github.com/SanTiepi/anthropie-edifice/issues">Issue GitHub</a> — correction sous 30 jours.</p>
			</section>

			<section>
				<h2>Pour les chercheurs</h2>
				<p>L'édifice est synthèse rapide d'évidence existante 2024-2025. Aucune validation longitudinale propre. Premières cohortes seront laboratoires. Sources détaillées en fin de chaque fichier de couche (~88 sources scientifiques mobilisées). Critique radicale bienvenue, surtout pour démolir ce qui ne tient pas.</p>
				<p>Vocabulaire&nbsp;: <a href={`${base}/lire/glossaire/`}>glossaire</a> (treize termes définis en une phrase chacun). Citation&nbsp;: voir le <a href={`${githubBase}/CITATION.cff`}>CITATION.cff</a> et le snippet BibTeX dans le <a href={`${githubBase}/README.md`}>README</a>.</p>
			</section>

			<section aria-labelledby="quatre-portes">
				<h2 id="quatre-portes">Quatre portes</h2>
				<p>Le corpus est dense. Pour entrer sans s'y perdre, choisir une porte selon votre intention.</p>
				<ol class="quatre-portes">
					<li>
						<strong>1. Comprendre</strong>
						<span class="porte-desc"> — situer ce qu'est l'édifice avant tout autre engagement.</span>
						<br /><a href={`${base}/lire/accueil/`}>pacte d'accueil 90 s</a> · <a href={`${base}/lire/adequation/`}>test d'adéquation 90 s</a> · <a href={`${base}/lire/brief/`}>brief 3 min</a> · <a href={`${base}/lire/noyau/`}>noyau 10 min</a> · <a href={`${base}/lire/apercu-12-couches/`}>aperçu des 12 couches 15 min</a>
					</li>
					<li>
						<strong>2. Pratiquer prudemment</strong>
						<span class="porte-desc"> — incarner sans nuire.</span>
						<br /><a href={`${base}/lire/garde-fous/`}>SAFETY</a> · <a href={`${base}/lire/prototyper/`}>format prototypes</a> · <a href={`${base}/lire/matrice-dispositifs/`}>matrice des dispositifs</a>
						<br /><em>Noyau opérationnel Couche 4</em>&nbsp;: <a href={`${base}/lire/kit-cercle-45/`}>Kit Cercle 45 min</a> · <a href={`${base}/lire/pav-toolkit/`}>Toolkit PAV</a> · <a href={`${base}/lire/sas-3-restes/`}>Sas des 3 Restes</a>
					</li>
					<li>
						<strong>3. Vérifier, critiquer</strong>
						<span class="porte-desc"> — démolir proprement plutôt qu'adhérer.</span>
						<br /><a href={`${base}/lire/preuves/`}>carte des preuves (A/B/C/D)</a> · <a href={`${base}/lire/refutation/`}>critères de réfutation</a> · <a href={`${base}/lire/griefs/`}>griefs ouverts</a> · <a href={`${base}/lire/auto-critique/`}>auto-critique anticipative</a>
					</li>
					<li>
						<strong>4. Porter, transmettre</strong>
						<span class="porte-desc"> — incarner publiquement et défendre la doctrine.</span>
